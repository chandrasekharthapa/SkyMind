# ============================================================
# SkyMind Frontend — Environment Variables
# Copy this file to .env.local and fill in real values.
# ============================================================

# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ── Backend API ───────────────────────────────────────────
# Primary key consumed by lib/api.ts
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Legacy alias (also supported as fallback)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Razorpay ──────────────────────────────────────────────
NEXT_PUBLIC_RAZORPAY_KEY=rzp_test_xxxxxxxxxxxx

# ── Mapbox (optional, for route map) ─────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1IjoiWU9VUl9VU0VSTkFNRSJ9...
