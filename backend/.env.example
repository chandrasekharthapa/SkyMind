# ============================================================
# SkyMind Backend — Environment Variables
# Copy to .env and fill in real values.
# NOTE: Amadeus API removed — no flight API keys needed.
# ============================================================

# ── App ───────────────────────────────────────────────────
SECRET_KEY=change-me-with-a-long-random-string
DEBUG=false

# ── Database ──────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=eyJ...YOUR_SERVICE_ROLE_KEY...
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres?sslmode=require

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Razorpay ──────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_SECRET

# ── Email (Gmail SMTP) ────────────────────────────────────
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
EMAIL_FROM_NAME=SkyMind Flights
EMAIL_REPLY_TO=support@skymind.app

# ── SMS / Notifications ───────────────────────────────────
FAST2SMS_API_KEY=YOUR_FAST2SMS_KEY

# ── Twilio ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=YOUR_TWILIO_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_TOKEN
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=https://skymind.vercel.app,https://www.skymind.app

# ── ML ────────────────────────────────────────────────────
MODEL_PATH=./ml/models
